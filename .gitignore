# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# zillow data CSVs (large files, download via scripts/download-zillow-data.sh)
data/zillow/*.csv
scripts/create-secrets.sh
.env*

# restore artifacts (Cloud Build archive recovery)
_restore/
*.tgz
.~lock.*

# claude settings
.claude/

# Python
venv/
**/venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
**/.venv/

# macOS
.DS_Store
**/.DS_Store

# Stale temp artifacts
.write-test

# Playwright e2e (Foundation Audit Z.0b — local-only artifacts)
playwright-report/
test-results/
playwright/.auth/

# Lighthouse CI (Foundation Audit Z.2 — local-only artifacts)
.lighthouseci/

# docs/handoff — keep local-only by default. The audit + bootstrap doc are
# whitelisted because they're agent-reference materials referenced by SLICES.md.
# Other files in this folder may contain customer data or shared credentials
# (e.g. handoff-2026-04-28.md mentions a shared bcrypt password) — review and
# redact before whitelisting any new ones.
docs/handoff/*
!docs/handoff/bms-audit-2026-04-28.md
!docs/handoff/bms-overhaul-bootstrap.md
!docs/handoff/bms-overhaul-retrospective-2026-05-02.md
!docs/handoff/audit-sprint-plan-2026-05-02.md
!docs/handoff/site-wide-speed-audit-2026-05-02.md
!docs/handoff/audit-roadmap-2026-q2-q4.md
!docs/handoff/speed-2026-q2-baselines.md
!docs/handoff/archive/
!docs/handoff/archive/**
!docs/handoff/speed-2026-q2-*.md
