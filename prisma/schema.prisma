model Portfolio {
  // NOTE: This table was created with camelCase column names (no migration ever
  // converted them to snake_case). DO NOT add @map("snake_case") directives to
  // these fields — production columns are camelCase. The previous snake_case
  // @map directives were schema drift that didn't match the actual DB.
  // Discovered during Phase 9 STEP 2 diagnosis. If you want to migrate to
  // snake_case, write a proper ALTER TABLE ... RENAME COLUMN migration.
  id             String              @id @default(uuid())
  orgId          String              @map("org_id")
  name           String // Primary entity name (e.g., "Parkway Management NY LLC")
  slug           String              @unique
  totalBuildings Int                 @default(0)
  totalUnits     Int                 @default(0)
  totalValue     Float               @default(0)
  avgDistress    Float               @default(0)
  borough        String?
  neighborhood   String?
