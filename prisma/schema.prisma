// ============================================================
model PromoteModel {
  id             String   @id @default(uuid())
  dealAnalysisId String   @map("deal_analysis_id")
  name           String?
  templateName   String?  @map("template_name")
  gpEquityPct    Float    @default(10) @map("gp_equity_pct")
  lpEquityPct    Float    @default(90) @map("lp_equity_pct")
  waterfallTiers Json     @default("[]") @map("waterfall_tiers")
  outputs        Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  dealAnalysis DealAnalysis @relation(fields: [dealAnalysisId], references: [id], onDelete: Cascade)

  @@index([dealAnalysisId])
  @@map("promote_models")
}

// ============================================================
// Twilio Phone System
// ============================================================

enum PhoneNumberStatus {
  active
  suspended
  released
}

enum MessageDirection {
  inbound
  outbound
}

enum SmsStatus {
  queued
  sent
  delivered
  failed
  received
}

enum CallDirection {
  inbound
  outbound
}

enum CallStatus {
  initiated
  ringing
  answered
  completed
  missed
  failed
}

model PhoneNumber {
  id               String            @id @default(uuid())
  number           String            @unique // E.164 format: +12125551234
  twilioSid        String            @unique @map("twilio_sid")
  friendlyName     String?           @map("friendly_name")
  areaCode         String?           @map("area_code")
  userId           String            @map("user_id")
  organizationId   String            @map("organization_id")
  status           PhoneNumberStatus @default(active)
  forwardingNumber String?           @map("forwarding_number") // user's real phone for call forwarding
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  smsMessages    SmsMessage[]
  calls          PhoneCall[]
  leasingConfigs LeasingConfig[]

  @@index([userId])
  @@index([organizationId])
  @@map("phone_numbers")
}

model SmsMessage {
  id            String           @id @default(uuid())
  phoneNumberId String           @map("phone_number_id")
  userId        String           @map("user_id")
  contactId     String?          @map("contact_id")
  direction     MessageDirection
  from          String
  to            String
  body          String           @db.Text
  status        SmsStatus        @default(queued)
  twilioSid     String?          @unique @map("twilio_sid")
  mediaUrls     Json             @default("[]") @map("media_urls")
  createdAt     DateTime         @default(now()) @map("created_at")

  phoneNumber PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact     Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([phoneNumberId, createdAt(sort: Desc)])
  @@index([userId, to])
  @@map("sms_messages")
}

model PhoneCall {
  id            String        @id @default(uuid())
  phoneNumberId String        @map("phone_number_id")
  userId        String        @map("user_id")
  contactId     String?       @map("contact_id")
  direction     CallDirection
  from          String
  to            String
  status        CallStatus    @default(initiated)
  duration      Int? // seconds
  recordingUrl  String?       @map("recording_url")
  twilioSid     String?       @unique @map("twilio_sid")
  createdAt     DateTime      @default(now()) @map("created_at")

  phoneNumber PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact     Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([phoneNumberId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("phone_calls")
}

model BrokerAgent {
  id     String  @id @default(uuid())
  orgId  String  @map("org_id")
  userId String? @unique @map("user_id")

  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  email     String
  phone     String?

  // Personal Info
  address     String?
  city        String?
  state       String?   @default("NY")
  zipCode     String?   @map("zip_code")
  dateOfBirth DateTime? @map("date_of_birth")

  // Brokerage Info
  startDate    DateTime? @map("start_date")
  teamOrOffice String?   @map("team_or_office")

  // Tax & Compliance Flags
  w9OnFile Boolean @default(false) @map("w9_on_file")

  // Media
  photoUrl String? @map("photo_url")

  // Internal
  notes String?

  licenseNumber String?   @map("license_number")
  licenseExpiry DateTime? @map("license_expiry")

  defaultSplitPct Decimal @default(70) @map("default_split_pct") @db.Decimal(5, 2)

  // Per-agent split overrides (null = use org defaults)
  houseExclusiveSplitPct    Decimal? @map("house_exclusive_split_pct") @db.Decimal(5, 2)
  personalExclusiveSplitPct Decimal? @map("personal_exclusive_split_pct") @db.Decimal(5, 2)

  status           String        @default("pending") // pending | active | inactive | terminated
  brokerageRole    BrokerageRole @default(agent) @map("brokerage_role")
  commissionPlanId String?       @map("commission_plan_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  dealSubmissions DealSubmission[]
  invoices        Invoice[]
  commissionPlan  CommissionPlan?  @relation(fields: [commissionPlanId], references: [id], onDelete: SetNull)

  eoInsuranceExpiry   DateTime?            @map("eo_insurance_expiry")
  complianceDocuments ComplianceDocument[]
  payments            Payment[]
  transactions        Transaction[]
  bmsListings         BmsListing[]

  // Invitation / Onboarding
  inviteToken      String?   @unique @map("invite_token")
  invitedAt        DateTime? @map("invited_at")
  inviteAcceptedAt DateTime? @map("invite_accepted_at")
  inviteEmail      String?   @map("invite_email")

  // Goals & Leaderboard
  goals  AgentGoal[]
  badges AgentBadge[]

  // Multi-agent deal splits
  transactionAgents TransactionAgent[]

  // AI Leasing Agent
  leasingConversations LeasingConversation[] @relation("LeasingShowingAgent")

  @@index([orgId])
  @@index([email])
  @@map("broker_agents")
}

model DealSubmission {
  id      String  @id @default(uuid())
  orgId   String  @map("org_id")
  agentId String? @map("agent_id")

  agentFirstName String  @map("agent_first_name")
  agentLastName  String  @map("agent_last_name")
  agentEmail     String  @map("agent_email")
  agentPhone     String? @map("agent_phone")
  agentLicense   String? @map("agent_license")

  propertyAddress String  @map("property_address")
  unit            String?
  city            String?
  state           String  @default("NY")

  dealType         BmsDealType @default(sale) @map("deal_type")
  transactionValue Decimal     @map("transaction_value") @db.Decimal(14, 2)
  closingDate      DateTime?   @map("closing_date")

  commissionType  String   @default("percentage") @map("commission_type")
  commissionPct   Decimal? @map("commission_pct") @db.Decimal(5, 2)
  commissionFlat  Decimal? @map("commission_flat") @db.Decimal(12, 2)
  totalCommission Decimal  @map("total_commission") @db.Decimal(12, 2)
  agentSplitPct   Decimal  @map("agent_split_pct") @db.Decimal(5, 2)
  houseSplitPct   Decimal  @map("house_split_pct") @db.Decimal(5, 2)
  agentPayout     Decimal  @map("agent_payout") @db.Decimal(12, 2)
  housePayout     Decimal  @map("house_payout") @db.Decimal(12, 2)

  clientName      String? @map("client_name")
  clientEmail     String? @map("client_email")
  clientPhone     String? @map("client_phone")
  representedSide String? @map("represented_side")

  coBrokeAgent     String? @map("co_broke_agent")
  coBrokeBrokerage String? @map("co_broke_brokerage")

  // Multi-agent co-agents: [{ agentId?, name, email, splitPct, role }]
  coAgents Json? @map("co_agents")

  status          String  @default("submitted")
  rejectionReason String? @map("rejection_reason")
  notes           String?

  submissionSource String @default("internal") @map("submission_source")

  // Exclusive type: determines which split % applies
  exclusiveType String? @map("exclusive_type") // "brokerage" | "personal"

  // Link to BmsProperty when brokerage exclusive (auto-fills address, landlord, billing entity)
  bmsPropertyId String? @map("bms_property_id")

  // Landlord / billing info (auto-filled from BmsProperty for brokerage exclusive, or manually entered for personal)
  landlordName    String? @map("landlord_name")
  landlordEmail   String? @map("landlord_email")
  landlordPhone   String? @map("landlord_phone")
  landlordAddress String? @map("landlord_address")
  managementCo    String? @map("management_co")

  // Lease-specific fields
  leaseStartDate DateTime? @map("lease_start_date")
  leaseEndDate   DateTime? @map("lease_end_date")
  monthlyRent    Decimal?  @map("monthly_rent") @db.Decimal(12, 2)

  // Tenant / Buyer info (rename-safe: clientName already exists, these are additional)
  tenantName  String? @map("tenant_name")
  tenantEmail String? @map("tenant_email")
  tenantPhone String? @map("tenant_phone")

  // Required document tracking (stores which required docs have been uploaded)
  // Values: { signedLease: boolean, agencyDisclosure: boolean, fairHousing: boolean, commissionAgreement: boolean }
  requiredDocs Json? @map("required_docs")

  // Manager override fields
  managerOverrideExclusiveType String?   @map("manager_override_exclusive_type")
  managerOverrideSplitPct      Decimal?  @map("manager_override_split_pct") @db.Decimal(5, 2)
  approvedBy                   String?   @map("approved_by")
  approvedAt                   DateTime? @map("approved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agent        BrokerAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)
  bmsProperty  BmsProperty? @relation(fields: [bmsPropertyId], references: [id], onDelete: SetNull)
  invoice      Invoice?
  transaction  Transaction?

  @@index([orgId, status])
  @@index([agentEmail])
  @@map("deal_submissions")
}

model Invoice {
  id            String @id @default(uuid())
  orgId         String @map("org_id")
  invoiceNumber String @unique @map("invoice_number")

  dealSubmissionId String? @unique @map("deal_submission_id")
  agentId          String? @map("agent_id")

  brokerageName    String  @map("brokerage_name")
  brokerageAddress String? @map("brokerage_address")
  brokeragePhone   String? @map("brokerage_phone")
  brokerageEmail   String? @map("brokerage_email")
  brokerageLicense String? @map("brokerage_license")

  agentName    String  @map("agent_name")
  agentEmail   String? @map("agent_email")
  agentLicense String? @map("agent_license")

  propertyAddress  String      @map("property_address")
  dealType         BmsDealType @default(sale) @map("deal_type")
  transactionValue Decimal     @map("transaction_value") @db.Decimal(14, 2)
  closingDate      DateTime?   @map("closing_date")
  clientName       String?     @map("client_name")
  representedSide  String?     @map("represented_side")

  totalCommission Decimal @map("total_commission") @db.Decimal(12, 2)
  agentSplitPct   Decimal @map("agent_split_pct") @db.Decimal(5, 2)
  houseSplitPct   Decimal @map("house_split_pct") @db.Decimal(5, 2)
  agentPayout     Decimal @map("agent_payout") @db.Decimal(12, 2)
  housePayout     Decimal @map("house_payout") @db.Decimal(12, 2)

  paymentTerms String    @default("Net 30") @map("payment_terms")
  issueDate    DateTime  @default(now()) @map("issue_date")
  dueDate      DateTime  @map("due_date")
  paidDate     DateTime? @map("paid_date")

  status InvoiceStatus @default(draft)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dealSubmission DealSubmission? @relation(fields: [dealSubmissionId], references: [id], onDelete: SetNull)
  agent          BrokerAgent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  payments       Payment[]
  transaction    Transaction?

  @@index([orgId, status])
  @@index([invoiceNumber])
  @@map("invoices")
}

model CommissionPlan {
  id          String             @id @default(uuid())
  orgId       String             @map("org_id")
  name        String
  description String?
  planType    CommissionPlanType @default(flat) @map("plan_type")
  isDefault   Boolean            @default(false) @map("is_default")
  status      String             @default("active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tiers        CommissionTier[]
  agents       BrokerAgent[]

  @@index([orgId])
  @@map("commission_plans")
}

model CommissionTier {
  id            String   @id @default(uuid())
  planId        String   @map("plan_id")
  tierOrder     Int      @default(0) @map("tier_order")
  minThreshold  Decimal  @default(0) @map("min_threshold") @db.Decimal(14, 2)
  maxThreshold  Decimal? @map("max_threshold") @db.Decimal(14, 2)
  agentSplitPct Decimal  @map("agent_split_pct") @db.Decimal(5, 2)
  houseSplitPct Decimal  @map("house_split_pct") @db.Decimal(5, 2)
  label         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plan CommissionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, tierOrder])
  @@map("commission_tiers")
}

model ComplianceDocument {
  id      String @id @default(uuid())
  orgId   String @map("org_id")
  agentId String @map("agent_id")

  docType     ComplianceDocType @map("doc_type")
  title       String
  description String?
  issueDate   DateTime?         @map("issue_date")
  expiryDate  DateTime?         @map("expiry_date")

  fileUrl  String? @map("file_url")
  fileName String? @map("file_name")
  fileSize Int?    @map("file_size")

  status String  @default("active")
  notes  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agent        BrokerAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([orgId, agentId])
  @@index([expiryDate])
  @@map("compliance_documents")
}

model Payment {
  id        String  @id @default(uuid())
  orgId     String  @map("org_id")
  invoiceId String  @map("invoice_id")
  agentId   String? @map("agent_id")

  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(check) @map("payment_method")
  paymentDate   DateTime      @default(now()) @map("payment_date")

  referenceNumber  String? @map("reference_number")
  stripePaymentId  String? @unique @map("stripe_payment_id")
  stripeTransferId String? @unique @map("stripe_transfer_id")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  agent        BrokerAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([invoiceId])
  @@index([agentId])
  @@index([stripePaymentId])
  @@map("payments")
}

model FileAttachment {
  id         String @id @default(uuid())
  orgId      String @map("org_id")
  entityType String @map("entity_type")
  entityId   String @map("entity_id")

  fileName    String  @map("file_name")
  fileType    String  @map("file_type")
  fileSize    Int     @map("file_size")
  storagePath String  @map("storage_path")
  publicUrl   String? @map("public_url")
  uploadedBy  String? @map("uploaded_by")

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, entityType, entityId])
  @@index([entityId])
  @@map("file_attachments")
}

// ============================================================
// BMS: Transaction Management
// ============================================================

model Transaction {
  id               String  @id @default(uuid())
  orgId            String  @map("org_id")
  dealSubmissionId String? @unique @map("deal_submission_id")
  agentId          String? @map("agent_id")

  // Type and stage
  type  BmsTransactionType
  stage TransactionStage   @default(application)

  // Property info (snapshotted or entered manually)
  propertyAddress String  @map("property_address")
  propertyUnit    String? @map("property_unit")
  propertyCity    String? @map("property_city")
  propertyState   String? @default("NY") @map("property_state")
  propertyName    String? @map("property_name")

  // Deal info
  transactionValue Decimal? @map("transaction_value") @db.Decimal(12, 2)
  commissionAmount Decimal? @map("commission_amount") @db.Decimal(12, 2)

  // Parties
  clientName      String? @map("client_name")
  clientEmail     String? @map("client_email")
  clientPhone     String? @map("client_phone")
  otherPartyName  String? @map("other_party_name")
  otherPartyEmail String? @map("other_party_email")
  otherPartyPhone String? @map("other_party_phone")

  // Key dates (milestones)
  applicationDate DateTime? @map("application_date")
  approvalDate    DateTime? @map("approval_date")
  contractDate    DateTime? @map("contract_date")
  inspectionDate  DateTime? @map("inspection_date")
  closingDate     DateTime? @map("closing_date")
  moveInDate      DateTime? @map("move_in_date")
  leaseStartDate  DateTime? @map("lease_start_date")
  leaseEndDate    DateTime? @map("lease_end_date")
  expirationDate  DateTime? @map("expiration_date")
  actualCloseDate DateTime? @map("actual_close_date")

  // Notes
  notes String?

  // Link to listing (one-to-one optional — set when created from a listing lease-up)
  listingId String? @unique @map("listing_id")

  // Link to invoice (one-to-one optional)
  invoiceId String? @unique @map("invoice_id")

  // Agent payout tracking (money OUT to agent)
  agentSplitPct        Decimal?  @map("agent_split_pct") @db.Decimal(5, 2)
  agentPayoutAmount    Decimal?  @map("agent_payout_amount") @db.Decimal(12, 2)
  housePayoutAmount    Decimal?  @map("house_payout_amount") @db.Decimal(12, 2)
  agentPayoutDate      DateTime? @map("agent_payout_date")
  agentPayoutMethod    String?   @map("agent_payout_method")
  agentPayoutReference String?   @map("agent_payout_reference")
  agentPayoutStatus    String?   @default("pending") @map("agent_payout_status")

  // Lifecycle timestamps
  invoiceCreatedAt     DateTime? @map("invoice_created_at")
  invoiceSentAt        DateTime? @map("invoice_sent_at")
  commissionReceivedAt DateTime? @map("commission_received_at")
  agentPaidAt          DateTime? @map("agent_paid_at")

  // Metadata
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  closedAt     DateTime? @map("closed_at")
  cancelledAt  DateTime? @map("cancelled_at")
  cancelReason String?   @map("cancel_reason")

  // Relations
  organization   Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  dealSubmission DealSubmission?    @relation(fields: [dealSubmissionId], references: [id], onDelete: SetNull)
  agent          BrokerAgent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  listing        BmsListing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)
  invoice        Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  tasks          TransactionTask[]
  agents         TransactionAgent[]

  @@index([orgId, stage])
  @@index([orgId, type])
  @@index([orgId, agentId])
  @@index([invoiceId])
  @@map("transactions")
}

model TransactionAgent {
  id            String @id @default(uuid())
  transactionId String @map("transaction_id")
  agentId       String @map("agent_id")

  role         String   @default("primary") // "primary" | "co_agent" | "referral"
  splitPct     Decimal? @map("split_pct") @db.Decimal(5, 2)
  payoutAmount Decimal? @map("payout_amount") @db.Decimal(12, 2)

  // Payout tracking
  payoutStatus    String    @default("pending") @map("payout_status") // "pending" | "processing" | "paid"
  payoutDate      DateTime? @map("payout_date")
  payoutMethod    String?   @map("payout_method")
  payoutReference String?   @map("payout_reference")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  agent       BrokerAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([transactionId, agentId])
  @@index([transactionId])
  @@index([agentId])
  @@map("transaction_agents")
}

model TransactionTask {
  id            String @id @default(uuid())
  transactionId String @map("transaction_id")

  title       String
  description String?
  stage       TransactionStage
  sortOrder   Int              @default(0) @map("sort_order")
  isCompleted Boolean          @default(false) @map("is_completed")
  completedAt DateTime?        @map("completed_at")
  completedBy String?          @map("completed_by")
  dueDate     DateTime?        @map("due_date")
  notes       String?
  isRequired  Boolean          @default(false) @map("is_required")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId, stage])
  @@map("transaction_tasks")
}

model TransactionTemplate {
  id        String             @id @default(uuid())
  orgId     String             @map("org_id")
  name      String
  type      BmsTransactionType
  isDefault Boolean            @default(false) @map("is_default")
  isActive  Boolean            @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tasks        TransactionTemplateTask[]

  @@index([orgId, type])
  @@map("transaction_templates")
}

model TransactionTemplateTask {
  id         String @id @default(uuid())
  templateId String @map("template_id")

  title          String
  description    String?
  stage          TransactionStage
  sortOrder      Int              @default(0) @map("sort_order")
  isRequired     Boolean          @default(false) @map("is_required")
  defaultDueDays Int?             @map("default_due_days")

  template TransactionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("transaction_template_tasks")
}

// ============================================================
// LISTINGS & PROPERTY MANAGEMENT
// ============================================================

model BmsProperty {
  id    String @id @default(uuid())
  orgId String @map("org_id")

  name    String
  address String?
  city    String? @default("New York")
  state   String? @default("NY")
  zipCode String? @map("zip_code")

  // Landlord / Management info
  landlordName  String? @map("landlord_name")
  landlordEmail String? @map("landlord_email")
  landlordPhone String? @map("landlord_phone")
  managementCo  String? @map("management_co")

  totalUnits Int?    @map("total_units")
  notes      String?

  // Exclusive building flag — marks this as a brokerage-exclusive listing
  isExclusive Boolean @default(false) @map("is_exclusive")

  // Billing entity for commission invoices (may differ from landlordName)
  billingEntityName    String? @map("billing_entity_name")
  billingEntityAddress String? @map("billing_entity_address")
  billingEntityEmail   String? @map("billing_entity_email")
  billingEntityPhone   String? @map("billing_entity_phone")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  listings        BmsListing[]
  leasingConfig   LeasingConfig?
  dealSubmissions DealSubmission[]

  @@index([orgId])
  @@index([orgId, name])
  @@map("bms_properties")
}

model BmsListing {
  id         String  @id @default(uuid())
  orgId      String  @map("org_id")
  propertyId String? @map("property_id")

  // Address
  address String
  unit    String?
  city    String? @default("New York")
  state   String? @default("NY")
  zipCode String? @map("zip_code")

  // Type & Status
  type   BmsListingType   @default(rental)
  status BmsListingStatus @default(available)

  // Pricing
  rentPrice   Decimal? @map("rent_price") @db.Decimal(12, 2)
  askingPrice Decimal? @map("asking_price") @db.Decimal(12, 2)

  // Unit details
  bedrooms    String?
  bathrooms   String?
  sqft        Int?
  floor       String?
  description String?
  amenities   String[] @default([])

  // Availability
  availableDate DateTime? @map("available_date")
  daysOnMarket  Int?      @map("days_on_market")

  // Commission
  commissionType   BmsCommissionType? @map("commission_type")
  commissionAmount Decimal?           @map("commission_amount") @db.Decimal(12, 2)
  commissionPct    Decimal?           @map("commission_pct") @db.Decimal(5, 2)

  // Assignment
  agentId String? @map("agent_id")

  // Tenant (populated at application+ stage)
  tenantName     String?   @map("tenant_name")
  tenantEmail    String?   @map("tenant_email")
  tenantPhone    String?   @map("tenant_phone")
  leaseStartDate DateTime? @map("lease_start_date")
  leaseEndDate   DateTime? @map("lease_end_date")

  // Notes
  notes String?

  // Status change timestamps
  showingStartedAt DateTime? @map("showing_started_at")
  applicationAt    DateTime? @map("application_at")
  approvedAt       DateTime? @map("approved_at")
  leasedAt         DateTime? @map("leased_at")
  offMarketAt      DateTime? @map("off_market_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organization         Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  property             BmsProperty?          @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  agent                BrokerAgent?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  transaction          Transaction?
  leasingConversations LeasingConversation[]

  @@unique([propertyId, unit], map: "bms_listings_property_unit_unique")
  @@index([orgId, status])
  @@index([orgId, propertyId])
  @@index([orgId, agentId])
  @@index([orgId, type])
  @@map("bms_listings")
}

// ============================================================
// AGENT GOALS & LEADERBOARD
// ============================================================

model AgentGoal {
  id      String @id @default(uuid())
  orgId   String @map("org_id")
  agentId String @map("agent_id")

  // Period
  year  Int
  month Int // 1-12

  // Targets (nullable = no target set for this metric)
  dealsClosedTarget    Int?     @map("deals_closed_target")
  revenueTarget        Decimal? @map("revenue_target") @db.Decimal(12, 2)
  listingsLeasedTarget Int?     @map("listings_leased_target")
  listingsAddedTarget  Int?     @map("listings_added_target")

  // Custom targets (flexible JSON for future expansion)
  customTargets Json? @map("custom_targets")

  // Tracking (denormalized snapshots — updated periodically or on demand)
  dealsClosedActual    Int     @default(0) @map("deals_closed_actual")
  revenueActual        Decimal @default(0) @map("revenue_actual") @db.Decimal(12, 2)
  listingsLeasedActual Int     @default(0) @map("listings_leased_actual")
  listingsAddedActual  Int     @default(0) @map("listings_added_actual")

  lastCalculatedAt DateTime? @map("last_calculated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agent        BrokerAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([orgId, agentId, year, month])
  @@index([orgId, year, month])
  @@map("agent_goals")
}

model AgentBadge {
  id      String @id @default(uuid())
  orgId   String @map("org_id")
  agentId String @map("agent_id")

  type        String // "streak_3", "streak_6", "top_producer", etc.
  name        String // "3-Month Streak", "Top Producer", etc.
  description String?
  earnedAt    DateTime @default(now()) @map("earned_at")
  period      String? // "2026-02" — the month it was earned, if applicable

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agent        BrokerAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([orgId, agentId])
  @@map("agent_badges")
}

// ============================================================
// BUILDING INTELLIGENCE CACHE
// ============================================================

model BuildingCache {
  id        String   @id @default(uuid())
  bbl       String   @db.VarChar(10)
  source    String   @db.VarChar(40)
  data      Json
  fetchedAt DateTime @default(now()) @map("fetched_at")
  expiresAt DateTime @map("expires_at")

  @@unique([bbl, source])
  @@index([expiresAt])
  @@map("building_cache")
}

// ============================================================
// NEIGHBORHOOD VITALITY SNAPSHOTS
// Pre-computed commercial tenant mix scores per ZIP code
// ============================================================

model VitalitySnapshot {
  id            String   @id @default(cuid())
  zipCode       String   @map("zip_code") @db.VarChar(10)
  market        String   @default("nyc") @db.VarChar(10)
  score         Float
  level         String   @db.VarChar(20)
  ratio         Float
  confidence    String   @db.VarChar(10)
  positiveCount Int      @map("positive_count")
  negativeCount Int      @map("negative_count")
  poiData       Json     @map("poi_data")
  metadata      Json?
  calculatedAt  DateTime @default(now()) @map("calculated_at")
  expiresAt     DateTime @map("expires_at")

  @@unique([zipCode, market])
  @@index([market, level])
  @@index([expiresAt])
  @@map("vitality_snapshots")
}

// ============================================================
// AI LEASING AGENT
// ============================================================

model LeasingConfig {
  id         String @id @default(uuid())
  orgId      String @map("org_id")
  propertyId String @unique @map("property_id")

  tier           LeasingTier @default(free)
  isActive       Boolean     @default(true) @map("is_active")
  emailEnabled   Boolean     @default(false) @map("email_enabled")
  webChatEnabled Boolean     @default(false) @map("web_chat_enabled")
  voiceEnabled   Boolean     @default(false) @map("voice_enabled")
  slug           String?     @unique

  // Stripe billing
  stripeCustomerId     String? @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")

  // Twilio number assigned to this property
  twilioNumberId String? @map("twilio_number_id")

  // AI identity & personality
  aiName             String   @default("Leasing Assistant") @map("ai_name")
  aiTone             String   @default("professional_friendly") @map("ai_tone")
  greeting           String   @default("Hi! I'm the leasing assistant for this property. How can I help you today?")
  personality        String   @default("friendly")
  languages          String[] @default(["en"])
  customInstructions String?  @map("custom_instructions") @db.Text

  // Knowledge base (assembled from enrichment + manual input, cached JSON)
  buildingKnowledge  Json? @map("building_knowledge")
  autoEnrichmentData Json? @map("auto_enrichment_data")

  // Qualification criteria (JSON)
  qualCriteria Json @default("{}") @map("qual_criteria")

  // Operating hours
  officeHoursStart String? @map("office_hours_start")
  officeHoursEnd   String? @map("office_hours_end")
  timezone         String  @default("America/New_York")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization  Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  property      BmsProperty           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  twilioNumber  PhoneNumber?          @relation(fields: [twilioNumberId], references: [id], onDelete: SetNull)
  conversations LeasingConversation[]
  dailyUsage    LeasingDailyUsage[]

  @@index([orgId])
  @@index([orgId, isActive])
  @@map("leasing_configs")
}

model LeasingConversation {
  id       String @id @default(uuid())
  orgId    String @map("org_id")
  configId String @map("config_id")

  // Channel
  channel      ConversationChannel @default(sms)
  emailSubject String?             @map("email_subject")

  // Prospect info
  prospectPhone String  @map("prospect_phone")
  prospectName  String? @map("prospect_name")
  prospectEmail String? @map("prospect_email")

  // Status tracking
  status      ConversationStatus @default(active)
  temperature LeadTemperature    @default(warm)

  // AI context (JSON — qualification answers, preferences, etc.)
  qualData  Json    @default("{}") @map("qual_data")
  aiSummary String? @map("ai_summary")

  // Interested listing
  listingId String? @map("listing_id")

  // Escalation
  escalatedAt      DateTime?         @map("escalated_at")
  escalationReason EscalationReason? @map("escalation_reason")

  // Agent assignment (for showings / escalations)
  showingAgentId String?   @map("showing_agent_id")
  showingAt      DateTime? @map("showing_at")

  // Waitlist
  onWaitlist      Boolean   @default(false) @map("on_waitlist")
  waitlistAddedAt DateTime? @map("waitlist_added_at")
  waitlistUnits   String[]  @default([]) @map("waitlist_units")

  // CRM link (created after qualification)
  contactId String? @map("contact_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  config       LeasingConfig     @relation(fields: [configId], references: [id], onDelete: Cascade)
  listing      BmsListing?       @relation(fields: [listingId], references: [id], onDelete: SetNull)
  showingAgent BrokerAgent?      @relation("LeasingShowingAgent", fields: [showingAgentId], references: [id], onDelete: SetNull)
  contact      Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  messages     LeasingMessage[]
  followUps    LeasingFollowUp[]

  @@unique([configId, prospectPhone])
  @@unique([configId, prospectEmail], map: "leasing_conversations_config_email_unique")
  @@index([orgId, status])
  @@index([configId])
  @@index([prospectPhone])
  @@index([prospectEmail])
  @@map("leasing_conversations")
}

model LeasingMessage {
  id             String @id @default(uuid())
  conversationId String @map("conversation_id")

  sender         MessageSender
  channel        ConversationChannel @default(sms)
  body           String
  twilioSid      String?             @map("twilio_sid")
  deliveryStatus String?             @map("delivery_status")

  // AI metadata
  intentDetected  String? @map("intent_detected")
  confidenceScore Float?  @map("confidence_score")
  tokensUsed      Int?    @map("tokens_used")

  createdAt DateTime @default(now()) @map("created_at")

  conversation LeasingConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("leasing_messages")
}

model LeasingFollowUp {
  id             String @id @default(uuid())
  conversationId String @map("conversation_id")

  type            FollowUpType
  status          FollowUpStatus @default(pending)
  scheduledFor    DateTime       @map("scheduled_for")
  sentAt          DateTime?      @map("sent_at")
  messageBody     String?        @map("message_body")
  cadencePosition Int            @default(1) @map("cadence_position")
  variantId       String?        @map("variant_id")

  createdAt DateTime @default(now()) @map("created_at")

  conversation LeasingConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([conversationId])
  @@index([variantId])
  @@map("leasing_follow_ups")
}

model LeasingDailyUsage {
  id       String   @id @default(uuid())
  configId String   @map("config_id")
  date     DateTime @db.Date

  messagesAi      Int @default(0) @map("messages_ai")
  messagesInbound Int @default(0) @map("messages_inbound")
  tokensUsed      Int @default(0) @map("tokens_used")

  config LeasingConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, date])
  @@index([configId, date])
  @@map("leasing_daily_usage")
}

// ── Leasing Benchmarks (anonymous cross-building aggregation) ──

model LeasingBenchmark {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  segment    String // e.g. "nyc_small", "other_medium"
  metric     String // "avg_response_time_ms", "showing_conversion_rate", "escalation_rate", "messages_per_conversation"
  p25        Float
  p50        Float
  p75        Float
  sampleSize Int      @map("sample_size")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([date, segment, metric])
  @@map("leasing_benchmark")
}

// ============================================================
// REFERENCE DATA CATALOG
// Externalized rates, benchmarks, tax tables, cost estimates
// Versioned with effective dates for audit trail + rollback
// ============================================================

model ReferenceDataCatalog {
  id            String    @id @default(uuid())
  orgId         String?   @map("org_id")
  category      String    @db.VarChar(50) // expense_benchmarks, rgb_rates, tax_tables, renovation_costs, closing_cost_rates, fhfa_hpi
  subcategory   String    @db.VarChar(80) // pre_war_elevator, manhattan, light_renovation, etc.
  version       Int       @default(1)
  data          Json
  source        String    @db.VarChar(120) // rgb_board_2025, dof_assessment_2024, etc.
  effectiveDate DateTime  @map("effective_date")
  expiresAt     DateTime? @map("expires_at")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, category, subcategory, version])
  @@index([category, subcategory, effectiveDate])
  @@index([orgId, category])
  @@map("reference_data_catalog")
}

model ReferenceDataAudit {
  id           String   @id @default(uuid())
  catalogId    String   @map("catalog_id")
  userId       String?  @map("user_id")
  action       String   @db.VarChar(20) // created, updated, expired
  oldData      Json?    @map("old_data")
  newData      Json     @map("new_data")
  changeReason String   @map("change_reason") @db.VarChar(200)
  changedAt    DateTime @default(now()) @map("changed_at")

  @@index([catalogId, changedAt])
  @@map("reference_data_audit")
}

// ============================================================
// CENSUS TRACT CACHE
// Persistent cache for Census ACS demographic data
// ============================================================

model CensusTractCache {
  id          String   @id @default(uuid())
  stateFips   String   @map("state_fips") @db.VarChar(2)
  countyFips  String   @map("county_fips") @db.VarChar(3)
  censusTract String   @map("census_tract") @db.VarChar(10)
  year        Int
  data        Json
  fetchedAt   DateTime @default(now()) @map("fetched_at")
  expiresAt   DateTime @map("expires_at")

  @@unique([stateFips, countyFips, censusTract, year])
  @@index([expiresAt])
  @@map("census_tract_cache")
}
