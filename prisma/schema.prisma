// VettdRE Database Schema
// Prisma ORM schema for PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "condo_ownership"]
}

// ============================================================
// ENUMS
// ============================================================

